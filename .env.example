# 외부 호출 안정성 튜닝(초/횟수). 미설정 시 코드 기본값 사용.
# HTTP_TIMEOUT=15        # Supabase 등 일반 REST 타임아웃
# HTTP_LLM_TIMEOUT=120   # LiteLLM 추론 타임아웃(느리므로 넉넉히)
# HTTP_MAX_RETRIES=3     # 429/5xx/연결끊김/타임아웃 재시도 횟수
# HTTP_RETRY_BACKOFF=0.5 # 재시도 지수 백오프 기준(0.5s,1s,2s...)

